<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title></title>
  </head>
  <body>
    <script>
      window.erxesEnv = <%- env %>;

      <% if (locals.kbTopicId) { %>
       window.knowledgebaseSettings = {
         topic_id: "<%= kbTopicId %>"
       }
      <% } %>
    </script>

    <div id="root"></div>

    <%# ROOT_URL 기준 절대경로로 번들 로드 — 리버스 프록시 경로 접두사(예: /widgets)를 보존한다.
        ROOT_URL이 비어 있으면 같은 호스트 루트절대경로로 폴백. %>
    <% var bundleSrc = ((JSON.parse(env).ROOT_URL || '').replace(/\/$/, '')) + '/build/' + type + '.bundle.js'; %>
    <script
      src="<%= bundleSrc %>"
      onerror="(function(){try{if(window.parent!==window)window.parent.postMessage({type:'widget-bundle-error',widgetType:'<%= type %>',src:'<%= bundleSrc %>'},'*');}catch(e){}})()"
    ></script>
  </body>
</html>
