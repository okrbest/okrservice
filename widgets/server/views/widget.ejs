<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title></title>
  </head>
  <body>
    <script>
      window.erxesEnv = <%- env %>;

      <% if (locals.kbTopicId) { %>
       window.knowledgebaseSettings = {
         topic_id: "<%= kbTopicId %>"
       }
      <% } %>
    </script>

    <div id="root"></div>

    <%# 같은 호스트에서 번들 제공(로컬에서 ROOT_URL과 접속 URL 불일치 시 404 방지). CDN 분리 시 서버에서 절대경로 주입을 커스터마이징하세요. %>
    <script
      src="/build/<%= type %>.bundle.js"
      onerror="(function(){try{if(window.parent!==window)window.parent.postMessage({type:'widget-bundle-error',widgetType:'<%= type %>',src:'/build/<%= type %>.bundle.js'},'*');}catch(e){}})()"
    ></script>
  </body>
</html>
